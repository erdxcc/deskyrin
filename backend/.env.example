PORT=3001
# Comma-separated allowed origins in production (e.g. https://your-app.vercel.app)
CORS_ORIGIN=
# Путь к SQLite (создаётся автоматически)
DATABASE_PATH=./data/recycling.db
# Секрет для шифрования приватных ключей кастодиальных кошельков (минимум 32 символа в проде)
WALLET_ENCRYPTION_SECRET=change-me-to-a-long-random-string-for-dev-only
# Опционально: ключ для админ-эндпоинтов (регистрация QR, партнёры)
ADMIN_API_KEY=dev-admin-key
# JWT для сессий (минимум 32 случайных символа в проде)
JWT_SECRET=change-me-jwt-secret-min-32-chars-long!!
JWT_EXPIRES_IN=7d

# --- Solana (optional: if unset, mint/recycle are DB-only demo) ---
SOLANA_RPC_URL=https://api.devnet.solana.com
RECYCLING_PROGRAM_ID=4mpEQjcASo912VDw8HtW89Ps44T4q8BaaVpYPRup4AQi
USDC_MINT=
# JSON array of 64 secret key bytes (same wallet as on-chain pool `partner`)
SOLANA_PARTNER_KEYPAIR=
# Public key of that wallet (for npm run db:seed partner row)
SOLANA_PARTNER_PUBKEY=
